# ============================================================
# OTSS Notification Service — Environment Variables
# Copy to .env and fill in values before running.
# ============================================================

NODE_ENV=development
PORT=3050

# PostgreSQL
DATABASE_URL=postgresql://postgres:admin@localhost:5432/otss_notification_service

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=notification-service

# Gmail SMTP
# GMAIL_USER    — your Gmail address e.g. yourname@gmail.com
# GMAIL_APP_PASSWORD — App Password generated from Google Account
#   Steps to get App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already enabled
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Select "Mail" and your device, click Generate
#   5. Copy the 16-character password shown
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Base URL of the frontend/client app
# Used to generate ticket tracking links in emails
# e.g. http://localhost:3000 for local dev
APP_BASE_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_REQUEST_BODY_DEBUG=false
