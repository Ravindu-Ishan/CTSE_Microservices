# ============================================================
# OTSS Queue Service — Environment Variables
# Copy to .env and fill in values before running.
# ============================================================

NODE_ENV=development
PORT=3040

# PostgreSQL
DATABASE_URL=postgresql://postgres:admin@localhost:5432/otss_queue_service

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=queue-service

# Internal service URLs — use K8s DNS names in staging/prod
USER_SERVICE_URL=http://localhost:3010
TICKET_SERVICE_URL=http://localhost:3030

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_REQUEST_BODY_DEBUG=false
