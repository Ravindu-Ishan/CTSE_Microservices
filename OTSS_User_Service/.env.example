PORT=3000
DATABASE_URL="postgresql://username:password@localhost:5432/otss_user_service?schema=public"
LOG_LEVEL=info
LOG_TO_FILE=false

# WSO2 SCIM2 provisioning (register a Service Provider in WSO2 with client_credentials grant)
WSO2_SCIM_BASE_URL="https://localhost:9443"
WSO2_CLIENT_ID=""
WSO2_CLIENT_SECRET=""

# WSO2 webhook signature verification (set in WSO2 Console → Events → Webhook → Secret)
WSO2_WEBHOOK_SECRET=your-webhook-secret-here
