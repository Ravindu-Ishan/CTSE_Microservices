# ============================================================
# OTSS Ticket Service — Environment Variables
# Copy to .env and fill in values before running.
# ============================================================

NODE_ENV=development
PORT=3030

# PostgreSQL — Prisma connection string
DATABASE_URL=postgresql://postgres:admin@localhost:5432/otss_ticket_service

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ticket-service

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_REQUEST_BODY_DEBUG=false
